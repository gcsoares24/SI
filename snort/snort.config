preprocessor frag3_global
preprocessor frag3_engine

#Regra S1
event_filter gen_id 1, sig_id 1000001, type threshold, track by_dst, count 6, seconds 120
alert tcp any any -> any :2047 (msg:"S1 - Possivel varrimento de portos"; sid:1000001; rev:1;)

#Regra S2
event_filter gen_id 1, sig_id 1000002, type both, track by_src, count 7, seconds 30
alert tcp any any -> any 8080 (msg:"S2 - Ataque de forca bruta detetado"; flags:S; sid:1000002; rev:1;)

#Regra S3
event_filter gen_id 1, sig_id 1000003, type limit, track by_dst, count 5, seconds 45
alert icmp any any -> any any (msg:"S3 - Echo Request recebido"; itype:8; sid:1000003; rev:1;)

